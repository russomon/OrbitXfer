# Copy this file to electron-builder.env for a local notarized macOS build.
# Do not commit your real credentials.

# Use the Developer ID Application certificate already installed in your login keychain.
CSC_NAME=Developer ID Application: Your Name (TEAMID1234)

# Recommended notarization flow: App Store Connect API key.
APPLE_API_KEY=/absolute/path/to/AuthKey_ABC123DEFG.p8
APPLE_API_KEY_ID=ABC123DEFG
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000

# Alternative local flow: use a notarytool keychain profile instead.
# APPLE_KEYCHAIN_PROFILE=orbitxfer-notary
