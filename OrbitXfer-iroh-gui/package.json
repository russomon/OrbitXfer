{
  "name": "orbitxfer-iroh-gui",
  "version": "0.1.51",
  "description": "GUI wrapper for the OrbitXfer Iroh CLI",
  "main": "src/main.js",
  "scripts": {
    "sync:cli": "node ./scripts/sync-cli.js",
    "start": "electron .",
    "build:mac": "npm run sync:cli && electron-builder --mac",
    "build:win": "npm run sync:cli && electron-builder --win",
    "build:linux": "npm run sync:cli && electron-builder --linux"
  },
  "build": {
    "appId": "com.orbitolive.orbitxfer.iroh.gui",
    "productName": "OrbitXfer",
    "mac": {
      "icon": "assets/icon.icns",
      "extraResources": [
        {
          "from": "bin/orbitxfer-iroh-cli",
          "to": "orbitxfer-iroh-cli"
        }
      ]
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "extraResources": [
        {
          "from": "bin/orbitxfer-iroh-cli",
          "to": "orbitxfer-iroh-cli"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "bin/orbitxfer-iroh-cli.exe",
          "to": "orbitxfer-iroh-cli.exe"
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "license": "MIT"
}
